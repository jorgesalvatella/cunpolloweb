# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenPay (server-side)
OPENPAY_MERCHANT_ID=your_merchant_id
OPENPAY_PRIVATE_KEY=sk_your_private_key

# OpenPay (client-side — safe to expose)
NEXT_PUBLIC_OPENPAY_MERCHANT_ID=your_merchant_id
NEXT_PUBLIC_OPENPAY_PUBLIC_KEY=pk_your_public_key
NEXT_PUBLIC_OPENPAY_SANDBOX=true

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# Admin
ADMIN_PASSWORD=change-me-to-a-secure-password

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+529983871387
ADMIN_WHATSAPP_PHONES=whatsapp:+529981488987
